# Server
PORT=3100
HOST=127.0.0.1                 # bind to localhost; Nginx proxies to it
NODE_ENV=production

# Session
SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# Google OAuth (create a project in https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=https://pulse.chatfree.app/auth/callback

# Allowlist — comma-separated emails that may log in
ALLOWED_EMAILS=you@example.com

# Paths
NGINX_SITES_DIR=/etc/nginx/sites-enabled
COMPOSE_BASE_DIR=/mnt/HC_Volume_102971677
DB_PATH=/var/lib/channels-monitor/metrics.db

# Nginx process name used for ss grep (the worker process listed by `ps aux | grep nginx`)
NGINX_PROCESS_NAME=nginx

# Docker compose binary invocation: "docker compose" (v2 plugin) or "docker-compose" (legacy v1)
DOCKER_COMPOSE_CMD=docker compose

# Retention
RETENTION_DAYS=30
